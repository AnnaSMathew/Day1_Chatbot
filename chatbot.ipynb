import gradio as gr
from groq import Groq


client = Groq(
    api_key="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"
)


def respond(message, history, system_prompt, temperature):
  
    messages = [{"role": "system", "content": system_prompt}]
    
    for turn in history:
        messages.append({"role": turn["role"], "content": turn["content"]})
        
    messages.append({"role": "user", "content": message})
    

    response = client.chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=messages,
        temperature=temperature,
        stream=True  # Required for real-time text delivery
    )

    partial_message = ""
    for chunk in response:
        if chunk.choices[0].delta.content is not None:
            partial_message += chunk.choices[0].delta.content
            yield partial_message


additional_inputs = [
    gr.Textbox(
        value="You are a helpful AI assistant. Respond concisely.",
        label="System Prompt",
        lines=3
    ),
    gr.Slider(
        minimum=0.0,
        maximum=2.0,
        value=0.1,
        step=0.1,
        label="Temperature"
    )
]


demo = gr.ChatInterface(
    fn=respond, 
    type="messages", 
    title="AI assisstant",
    additional_inputs=additional_inputs,
    additional_inputs_accordion=gr.Accordion(label="Parameters", open=True)
)

if __name__ == "__main__":
    # Added share=True so Gradio creates a public link outside Colab's iframe
    demo.launch(share=True, debug=True)
